# ===================================
# VARIABLES DE ENTORNO - TIENDA MANAGER
# ===================================

# Copia este archivo como .env.local para desarrollo
# o .env.production para producción

# ===== API =====
VITE_API_URL=http://localhost:3000/api

# Si usas XAMPP:
# VITE_API_URL=http://localhost/tienda-api

# ===== APLICACIÓN =====
VITE_APP_NAME=Tienda Manager
VITE_APP_VERSION=1.0.0

# ===== MONEDA =====
VITE_MONEDA=USD
VITE_LOCALE=es-ES

# ===== IMPUESTOS =====
VITE_IMPUESTO_DEFECTO=16

# ===== BASE DE DATOS (si está en el frontend) =====
# VITE_DB_HOST=localhost
# VITE_DB_USER=root
# VITE_DB_PASSWORD=
# VITE_DB_NAME=tienda_gestion

# ===== SEGURIDAD =====
# VITE_JWT_SECRET=tu-secret-aqui
# VITE_SESSION_TIMEOUT=3600000

# ===== CARACTERÍSTICAS =====
VITE_ENABLE_NOTIFICACIONES=true
VITE_ENABLE_REPORTES=true
VITE_ENABLE_EXPORT_PDF=true

# ===== LOGGING =====
VITE_LOG_LEVEL=info
# Valores: debug, info, warn, error

# ===== AXIOS =====
VITE_REQUEST_TIMEOUT=30000
